OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model routing
OPENROUTER_MODEL_FAST=google/gemma-4-31b-it:free
OPENROUTER_MODEL_SMART=nvidia/nemotron-3-super-120b-a12b:free

# LM Studio (optional — high-risk commands route here when set)
LM_STUDIO_URL=
LM_STUDIO_MODEL=local-model

# Storage
USE_VECTOR_STORE=true

# Security profile: developer | safe | custom
SECURITY_PROFILE=developer

# Timeouts (seconds)
MAX_COMMAND_TIMEOUT_SECONDS=30
SESSION_TIMEOUT_SECONDS=3600
